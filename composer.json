{
  "name": "golpilolz/db-configs",
  "type": "symfony-bundle",
  "description": "Store configurations in the database and use them in your Symfony application.",
  "keywords": ["bundle", "symfony"],
  "license": "MIT",
  "authors": [
    {
      "name": "Golpilolz and other contributors",
      "homepage": "https://github.com/golpilolz/db-configs/graphs/contributors"
    }
  ],
  "autoload": {
    "psr-4": {
      "Golpilolz\\DBConfigs\\": ""
    },
    "exclude-from-classmap": [ "/Tests/" ]
  },
  "autoload-dev": {
    "psr-4": {
      "Golpilolz\\DBConfigs\\Tests\\": "Tests/"
    }
  },
  "require": {
    "php": ">=8.3",
    "doctrine/doctrine-bundle": "^3.2",
    "doctrine/orm": "^3.6",
    "symfony/dependency-injection": "^8",
    "symfony/framework-bundle": "^8"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "minimum-stability": "stable",
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "symfony/runtime": true
    }
  }
}
